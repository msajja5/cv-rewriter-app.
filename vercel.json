{
  "version": 2,
  "framework": null,
  "buildCommand": "echo 'no build'",
  "outputDirectory": "public",
  "functions": {
    "api/chat.js":       { "runtime": "nodejs20.x", "maxDuration": 30 },
    "api/health.js":     { "runtime": "nodejs20.x", "maxDuration": 10 },
    "api/transcribe.js": { "runtime": "nodejs20.x", "maxDuration": 10 }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "methods": ["OPTIONS"],
      "headers": {
        "Access-Control-Allow-Origin": "*",
        "Access-Control-Allow-Methods": "POST, GET, OPTIONS",
        "Access-Control-Allow-Headers": "Content-Type, x-groq-key, x-gemini-key, x-openrouter-key, x-deepgram-key"
      },
      "continue": true
    },
    { "src": "/api/chat",       "dest": "/api/chat.js" },
    { "src": "/api/transcribe", "dest": "/api/transcribe.js" },
    { "src": "/api/health",     "dest": "/api/health.js" },
    { "src": "/(.*)",           "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, GET, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, x-groq-key, x-gemini-key, x-openrouter-key, x-deepgram-key" }
      ]
    }
  ]
}
